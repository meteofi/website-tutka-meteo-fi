{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/protect-master.sh",
            "timeout": 10,
            "statusMessage": "Checking master-branch protection"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/eslint-changed.sh",
            "timeout": 60,
            "statusMessage": "Linting edited file"
          }
        ]
      }
    ]
  }
}
